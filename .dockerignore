# Dependencias y builds locales (no deben entrar al build context)
node_modules/
dist/

# Archivos de entorno de desarrollo (pueden contener secretos)
.env
.env.*
*.local

# Git
.git/
.gitignore

# Archivos de editor/IDE
.vscode/
.idea/
*.code-workspace
.claude/

# Tests y cobertura
coverage/
.nyc_output/

# Documentación interna
doc/
*.md
!README.md

# Archivos del sistema operativo
.DS_Store
Thumbs.db

# Logs
*.log

# Solo incluir el environment de dev (el de prod se compila con ng build)
# Ambos están en src/environments/ pero ng build elige el correcto;
# no necesitamos que Docker los procese manualmente
